.DS_Store
/.build
/Packages
/*.xcodeproj
xcuserdata/
DerivedData/
.swiftpm/
# Track the shared SPM scheme so its <EnvironmentVariables> (notably
# ACERVO_APP_GROUP_ID for the test bundle) survive `xcodebuild`'s
# auto-generation. Everything else under .swiftpm/ stays local.
!.swiftpm/
!.swiftpm/xcode/
!.swiftpm/xcode/xcshareddata/
!.swiftpm/xcode/xcshareddata/xcschemes/
!.swiftpm/xcode/xcshareddata/xcschemes/*.xcscheme
.netrc
/Package.resolved
/test_output_macos.txt
/bin/
*.profraw
/default.profraw
graphify-out/.*
graphify-out/cache/

# graphify codemap: commit the portable graph artifacts, ignore machine-specific
# markers (absolute paths), the regenerable cache, and the absolute-path manifest.
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/.graphify_detect.json
graphify-out/cache/
graphify-out/manifest.json
